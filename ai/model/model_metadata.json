{
  "model_name": "sanctions_screening_risk_threshold",
  "version": "2.0.0",
  "trained_at": "2026-06-14",
  "description": "v2: Two XGBoost regressors predict (t_block, t_review) directly. The v1 classifiers (model_binary.ubj, model_multiclass.ubj) are retained but DEPRECATED \u2014 not used in compute_thresholds() as of v2.",
  "thresholds": {
    "description": "Two dynamic thresholds are computed per account from overall_risk_score. The match_score from the screening system is then compared against them.",
    "formula": {
      "risk_adjustment": "(overall_risk_score - 50) * 0.5",
      "t_block": "clamp(75 - risk_adjustment, 40, 95)",
      "t_review": "clamp(50 - risk_adjustment, 20, 70)"
    },
    "decision_zones": {
      "BLOCK": "match_score >= t_block  \u2014 automatic block, no human review",
      "REVIEW": "t_review <= match_score < t_block  \u2014 routed to human analyst",
      "CLEAR": "match_score < t_review  \u2014 automatic pass"
    },
    "examples": [
      {
        "overall_risk_score": 10,
        "t_block": 95.0,
        "t_review": 70.0,
        "note": "very low-risk: almost nothing can block"
      },
      {
        "overall_risk_score": 50,
        "t_block": 75.0,
        "t_review": 50.0,
        "note": "neutral: same as static baseline"
      },
      {
        "overall_risk_score": 90,
        "t_block": 55.0,
        "t_review": 30.0,
        "note": "high-risk: triggers easily"
      }
    ]
  },
  "models": {
    "binary": {
      "file": "model_binary.ubj",
      "objective": "binary:logistic",
      "task": "Detect BLOCK vs not-BLOCK. Positive class = BLOCK.",
      "cv_roc_auc": 0.9999,
      "cv_f1_block": 0.961,
      "scale_pos_weight": 424.5,
      "status": "DEPRECATED as of v2 \u2014 kept for reference"
    },
    "multiclass": {
      "file": "model_multiclass.ubj",
      "objective": "multi:softprob",
      "classes": [
        "BLOCK",
        "CLEAR",
        "REVIEW"
      ],
      "task": "Three-class verdict. Preferred for final decision output.",
      "cv_macro_f1": 0.9964,
      "status": "DEPRECATED as of v2 \u2014 kept for reference"
    }
  },
  "input_features": [
    {
      "name": "account_type_enc",
      "type": "int",
      "encoding": "individual=0, business=1"
    },
    {
      "name": "kyc_completeness",
      "type": "float",
      "range": [
        0.0,
        1.0
      ]
    },
    {
      "name": "kyc_status_enc",
      "type": "int",
      "encoding": "complete=0, partial=1, pending=2, expired=3"
    },
    {
      "name": "is_pep",
      "type": "int",
      "encoding": "0 or 1"
    },
    {
      "name": "has_complex_ownership",
      "type": "int",
      "encoding": "0 or 1"

      "encoding": "low=0, medium=1, high=2"
    },
    {
      "name": "account_status_enc",
      "type": "int",
      "encoding": "active=0, suspended=1, closed=2"
    },
    {
      "name": "match_score",
      "type": "float",
      "range": [
        0.0,
        100.0
      ],
      "source": "screening system (Jaro-Winkler or equivalent, scaled 0-100)"
    },
